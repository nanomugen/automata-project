[node name="point_tutorial" parent="Phase/Start_State/tutorials" unique_id=1339971707 instance=ExtResource("9_gmwqm")]
position = Vector2(539, -102)
text = "Este é um ponto, pontos são acionados ao apertar o botão de ação, o ponto tem um valor associado. Quando o botão é acionado  este valor associado será contabilizado ao valor do jogador. Quando o valor do jogador for equivalente ao valor de uma ou mais saídas do estado atual, a saída será habilitada."

[node name="exit_tutorial" parent="Phase/Start_State/tutorials" unique_id=864717428 instance=ExtResource("9_gmwqm")]
position = Vector2(1835, -100)
text = "Esta é uma saída, ela tem um valor associado a ela, quando o seu valor associado for igual ao valor que o jogador acumulou durante o estado atual, ela será aberta. uma saída pode levar a algum outro estado dentro da mesma fase ou, caso seja uma saída final, a saída leva ao fim da fase, que é o objetivo."


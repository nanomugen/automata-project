[node name="tutorial_generic" parent="Phase/State" unique_id=1409517180 instance=ExtResource("9_gmwqm")]
position = Vector2(-18, -100)
text = "Dentro dos estados pode haver portas e botões que se associam entre si  e se combinam em cores, uma porta pode precisar ser acionada por um ou mais botões associados a ela, um botão pode também abrir mais de uma passagem. As portas também servem de plataforma, em algumas situações podem ajudar a alcançar pontos antes inacessíveis, inclusive em outros estados da mesma fase."

